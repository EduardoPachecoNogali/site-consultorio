generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Psychologist {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  status    String   @default("pending")
  pin       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
