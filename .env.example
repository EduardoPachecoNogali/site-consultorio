# Banco de dados
DATABASE_URL="postgresql://mindcare_app:senha@localhost:5432/saas_psicologia?schema=public"
# Branding
NEXT_PUBLIC_APP_NAME="PsicoLink"
NEXT_PUBLIC_APP_TAGLINE="Sua Jornada de Bem-Estar Mental"
NEXT_PUBLIC_APP_DESCRIPTION="Conecte-se com psicólogos licenciados através de consultas por vídeo seguras"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_VIDEO_BASE_URL="https://meet.seudominio.com"
NEXT_PUBLIC_SUPPORT_EMAIL="suporte@seudominio.com"

# Email (SMTP)
EMAIL_SERVER_HOST="smtp.seudominio.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="smtp-user"
EMAIL_SERVER_PASSWORD="smtp-password"
EMAIL_FROM="\"SuaMarca\" <no-reply@seudominio.com>"

# Google Meet (Google Calendar API)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/psychologists/google/callback"
# Tokens por psicologo ficam no banco: googleRefreshToken, googleCalendarId, googleEmail
# Use 32-byte key (ex: openssl rand -base64 32)
GOOGLE_TOKEN_ENCRYPTION_KEY=""
PSYCHOLOGIST_SESSION_SECRET=""
PATIENT_SESSION_SECRET=""
APP_SESSION_SECRET=""
GOOGLE_MEET_TIMEZONE="America/Sao_Paulo"
